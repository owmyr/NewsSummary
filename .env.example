# Google Gemini API key
GOOGLE_API_KEY="YOUR_KEY_HERE"

# Groq API key (optional). When set, English sources use Groq (Llama 3.1 70B)
# instead of Gemini for summarization. Portuguese sources always use Gemini.
# Groq free tier: 30 req/min, ~1440 req/day (vs Gemini's 5 req/min, 20 req/day).
# GROQ_API_KEY="your-groq-key-here"
# GROQ_MODEL="llama-3.3-70b-versatile"
# GROQ_RETRIES=3

# Firebase service account credentials — the FULL JSON as a string
FIREBASE_CREDENTIALS='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# Email sending (Gmail app password recommended)
SENDER_EMAIL="the-daily-bot@example.com"
SENDER_PASSWORD="your-16-char-app-password"

# Optional SMTP overrides (defaults work with Gmail)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=465

# News sources (comma-separated; names must be registered)
# SOURCES="bbc"

# Scraping & summarization
# ARTICLE_LIMIT=3
# BBC_NEWS_URL="https://www.bbc.com/news"
# G1_HOMEPAGE_URL="https://g1.globo.com"
# GEMINI_MODEL="gemini-2.5-flash"
# GEMINI_RETRIES=4
# CHUNK_MAX_WORDS=600
# SUMMARY_MIN_WORDS=40

# HTTP client
# HTTP_TIMEOUT_SECONDS=15.0
# HTTP_MAX_CONNECTIONS=10

# Concurrency
# SCRAPE_CONCURRENCY=5
# SUMMARIZE_CONCURRENCY=1  # Keep at 1 to stay under free-tier 5 req/min
# GEMINI_MIN_CALL_INTERVAL_SECONDS=13  # Spacing between Gemini calls

# Email dispatch
# EMAIL_BATCH_SIZE=50
# EMAIL_BATCH_DELAY_SECONDS=2

# Reliability
# CIRCUIT_BREAKER_THRESHOLD=3
# CIRCUIT_BREAKER_COOLDOWN_SECONDS=30.0

# Health check (Firestore doc id)
# HEALTH_DOC_ID="last_run"

# Logging
# LOG_LEVEL=INFO
